{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "identifier": "com.bookos.calc",
  "productName": "Bookos Calc",
  "mainBinaryName": "bookos-calc",
  "version": "0.6.1",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; connect-src ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "title": "Calculadora",
        "width": 380,
        "height": 620,
        "minWidth": 340,
        "minHeight": 560,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png"
    ],
    "targets": [
      "deb",
      "rpm"
    ],
    "publisher": "BookOS",
    "category": "Utility",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ],
        "desktopTemplate": "linux/desktop.hbs"
      },
      "rpm": {
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ],
        "desktopTemplate": "linux/desktop.hbs"
      }
    }
  }
}
